{
  "name": "kol-voice-agent",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "npm run dev --workspace=@kol/server",
    "dev:web": "npm run dev --workspace=@kol/web",
    "build": "npm run build --workspaces",
    "seed": "npm run seed --workspace=@kol/server",
    "test": "npm run test --workspace=@kol/server",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
